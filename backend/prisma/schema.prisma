generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Album {
  id          Int      @id @default(autoincrement())
  title       String
  date        String
  location    String
  description String
  coverImage  String
  createdAt   DateTime @default(now())
}